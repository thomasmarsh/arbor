// packages/api/turbo.json
{
  "extends": ["//"],
  "tasks": {
    "build": {
      "env": ["ARBOR_PG_URL"]
    },
    "test": {
      "env": ["ARBOR_PG_URL"]
    },
    "db:migrate": {
      "cache": false
    },
    "db:generate": {
      "inputs": ["src/**/*.sql"],
      "outputs": ["src/**/*.queries.ts"]
    }
  }
}
