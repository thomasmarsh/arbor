{
  "name": "arbor-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "dev": "dotenv -e packages/bff/.env.local -e packages/api/.env.local -e .env.mock -- turbo dev",
    "dev:mock": "dotenv -e packages/bff/.env.local -e packages/api/.env.local -e .env.mock -- turbo dev",
    "dev:bff": "dotenv -e packages/bff/.env.local -e packages/api/.env.local -e .env.bff  -- turbo dev",
    "dev:oidc": "dotenv -e packages/bff/.env.local -e packages/api/.env.local -e .env.oidc -- turbo dev",
    "dev:staging": "dotenv -e packages/bff/.env.staging.local -e packages/api/.env.local -e .env.staging -- turbo dev",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "lint": "eslint packages/*/src",
    "lint:fix": "eslint packages/*/src --fix",
    "format": "prettier --write .",
    "clean": "turbo clean && find packages -name 'dist' -type d -prune -exec rm -rf {} +",
    "setup:certs": "bash scripts/setup-certs.sh",
    "db:up": "scripts/db.sh up",
    "db:down": "scripts/db.sh down",
    "db:reset": "scripts/db.sh reset && dotenv -e packages/api/.env.local -- turbo db:migrate",
    "db:migrate": "dotenv -e packages/api/.env.local -- turbo db:migrate",
    "db:generate": "dotenv -e packages/api/.env.local -- turbo db:generate"
  },
  "packageManager": "pnpm@11.3.0",
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "prettier-plugin-organize-imports": "^4.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "peerDependencyRules": {
    "allowedVersions": {
      "nunjucks>chokidar": "4"
    }
  },
  "dependencies": {
    "valtio": "^2.3.2"
  }
}
