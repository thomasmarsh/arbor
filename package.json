{
  "name": "arbo-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --parallel",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "clean": "turbo clean && find packages -name 'dist' -type d -prune -exec rm -rf {} +"
  },
  "devDependencies": {
    "typescript-eslint": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "prettier-plugin-organize-imports": "^4.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "peerDependencyRules": {
    "allowedVersions": {
      "nunjucks>chokidar": "4"
    }
  }
}
