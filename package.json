{
  "name": "arbo-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "typecheck": "turbo typecheck",
    "lint": "eslint packages/*/src",
    "lint:fix": "eslint packages/*/src --fix",
    "format": "prettier --write .",
    "clean": "turbo clean && find packages -name 'dist' -type d -prune -exec rm -rf {} +"
  },
  "packageManager": "pnpm@11.3.0",
  "devDependencies": {
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "prettier-plugin-organize-imports": "^4.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "peerDependencyRules": {
    "allowedVersions": {
      "nunjucks>chokidar": "4"
    }
  },
  "dependencies": {
    "valtio": "^2.3.2"
  }
}
