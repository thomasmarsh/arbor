{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "noEmit": true,
    "tsBuildInfoFile": "node_modules/.tmp/tsconfig.app.tsbuildinfo"
  },
  "references": [
    { "path": "../common/tsconfig.build.json" },
    { "path": "../router/tsconfig.build.json" }
  ],
  "include": ["src"]
}
