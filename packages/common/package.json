{
  "name": "@arbo/common",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/store/react/index.js",
      "types": "./dist/store/react/index.d.ts"
    },
    "./http": {
      "import": "./dist/http/index.js",
      "types": "./dist/http/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "dev": "tsc -b --watch",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@effect/platform": "^0.96.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@effect/platform-browser": "^0.76.0",
    "@types/react": "^19.0.0",
    "effect": "^3.21.2",
    "react": "^19.0.0",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "@effect/platform-browser": "^0.76.0",
    "effect": "^3.21.2",
    "react": "^19.0.0"
  }
}
