{
  "name": "@arbo/common",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/store/react/index.js",
      "types": "./dist/store/react/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "dev": "tsc -b --watch",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "vitest": "^4.1.7",
    "@types/react": "^19.0.0",
    "react": "^19.0.0"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  }
}
