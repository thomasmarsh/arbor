# ── PostgreSQL ─────────────────────────────────────────────────────────────────
ARBO_PG_URL=postgresql://user:password@localhost:5432/arbo

# ── Oracle ─────────────────────────────────────────────────────────────────────
# Requires Oracle Instant Client on the host.
# See: https://node-oracledb.readthedocs.io/en/latest/user_guide/installation.html
ARBO_ORACLE_USER=user
ARBO_ORACLE_PASSWORD=password
ARBO_ORACLE_CONNECT_STRING=localhost:1521/XEPDB1

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001
