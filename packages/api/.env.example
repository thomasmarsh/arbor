# Copy this file to .env.local and change for local development
# ── PostgreSQL ─────────────────────────────────────────────────────────────────
ARBOR_PG_URL=postgresql://user:password@localhost:5432/arbor

# ── Oracle ─────────────────────────────────────────────────────────────────────
# Requires Oracle Instant Client on the host.
# See: https://node-oracledb.readthedocs.io/en/latest/user_guide/installation.html
ARBOR_ORACLE_USER=user
ARBOR_ORACLE_PASSWORD=password
ARBOR_ORACLE_CONNECT_STRING=localhost:1521/XEPDB1

# ── Server ─────────────────────────────────────────────────────────────────────
API_PORT=3001
