  },
  "devDependencies": {
    "@pgtyped/cli": "^2.3.0",
    "@pgtyped/runtime": "^2.3.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.17.0",
    "vitest": "^4.1.7"
  }
