# Copy this file to .env.local and change for develeopmentj

# ── OIDC (required when ARBO_AUTH_DISABLED=false) ───────────────────────────────
ARBO_OIDC_ISSUER=https://your-idp.example.com
ARBO_OIDC_CLIENT_ID=your-client-id
ARBO_OIDC_CLIENT_SECRET=your-client-secret

# Normal local dev — register this URI in your IDP:
ARBO_OIDC_REDIRECT_URI=http://localhost:3000/auth/callback

# To test auth locally with a host alias:
#   1. Add "127.0.0.1  arbo.local" to /etc/hosts
#   2. Register http://arbo.local:3000/auth/callback in your IDP
#   3. Uncomment:
# ARBO_OIDC_REDIRECT_URI=http://arbo.local:3000/auth/callback

# ── Session ─────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ARBO_SESSION_SECRET=change-me-to-a-32-char-minimum-secret!

# ── Upstream API ────────────────────────────────────────────────────────────────
ARBO_API_URL=http://localhost:3001

# ── Server ──────────────────────────────────────────────────────────────────────
BFF_PORT=3000

# ── Production (OpenShift pod 1) ────────────────────────────────────────────────
# Path where the built UI is copied/mounted inside the container.
# Set this when NODE_ENV=production so the BFF can serve the SPA.
# ARBO_UI_DIST=/app/ui-dist
