{
  "name": "@arbor/router",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./openapi": {
      "import": "./dist/openapi/index.js",
      "types": "./dist/openapi/index.d.ts"
    },
    "./client": {
      "import": "./dist/client/index.js",
      "types": "./dist/client/index.d.ts"
    },
    "./server": {
      "import": "./dist/server/index.js",
      "types": "./dist/server/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist *.tsbuildinfo",
    "bench:inference": "tsx scripts/inference-bench.ts",
    "examples": "tsx examples/basic-server.ts && tsx examples/basic-client.ts && tsx examples/query-params.ts && tsx examples/nested-routes.ts && tsx examples/openapi-output.ts && tsx examples/guards.ts && tsx examples/typed-client.ts && tsx examples/auth-protected.ts && tsx examples/rbac.ts"
  },
  "dependencies": {
    "@arbor/common": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
