{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "ARBOR_API_URL",
    "ARBOR_APP_URL",
    "ARBOR_AUTH_DISABLED",
    "ARBOR_BFF_URL",
    "ARBOR_OIDC_CLIENT_ID",
    "ARBOR_OIDC_CLIENT_SECRET",
    "ARBOR_OIDC_ISSUER",
    "ARBOR_OIDC_REDIRECT_URI",
    "ARBOR_SESSION_SECRET",
    "NODE_ENV",
    "PORT",
    "VITE_APP_URL",
    "VITE_AUTH_MODE",
    "VITE_OIDC_CLIENT_ID",
    "VITE_OIDC_ISSUER",
    "VITE_USE_HTTPS"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "*.tsbuildinfo"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "clean": {
      "cache": false
    },
    "db:migrate": {
      "cache": false,
      "passThroughEnv": ["ARBOR_PG_URL"]
    },
    "db:generate": {
      "inputs": ["src/**/*.sql"],
      "outputs": ["src/**/*.queries.ts"]
    },
    "db:generate:watch": {
      "cache": false,
      "persistent": true
    },
    "@arbor/api#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "*.tsbuildinfo"]
    }
  }
}
