# Root mode-env file reference
#
# These variables are injected at the workspace level by the dev:* scripts in
# package.json. They are NOT loaded automatically — dotenv-cli explicitly passes
# the right mode file (e.g. .env.mock, .env.bff) depending on which dev:* target
# you run.
#
# Machine-local secrets (DB URLs, OIDC credentials, session secrets) live in
# per-package .env.local files. See apps/api/.env.example and apps/bff/.env.example.
#
# ── Auth mode ────────────────────────────────────────────────────────────────────
#
# Controls the authentication strategy for both the UI and the API.
#
#   mock    — auth is bypassed entirely; no OIDC provider needed (dev:mock)
#   bff     — full OIDC via the BFF's session cookie (dev:bff, dev:staging)
#   oidc    — OIDC handled directly in the browser (dev:oidc)
#
VITE_AUTH_MODE=mock

# ── API auth bypass ──────────────────────────────────────────────────────────────
#
# When true, the API skips JWT/session validation on every request.
# Must be false in any environment where real auth is in play.
#
ARBOR_AUTH_DISABLED=true

# ── OIDC (UI-side; used in VITE_AUTH_MODE=oidc only) ────────────────────────────
#
# Browser-side OIDC credentials. These are public — no secrets here.
#
VITE_OIDC_ISSUER=http://localhost:8080/realms/arbor
VITE_OIDC_CLIENT_ID=arbor-ui

# ── App URL (UI-side) ────────────────────────────────────────────────────────────
#
# The base URL of the Vite dev server. Used to register post-login redirect URIs.
#
VITE_APP_URL=http://localhost:5173

# ── App URL (API-side; used in VITE_AUTH_MODE=bff/staging) ──────────────────────
#
# The URL the API uses to construct absolute links pointing at the UI.
#
ARBOR_APP_URL=https://localhost:5173

# ── HTTPS dev server ─────────────────────────────────────────────────────────────
#
# Set to "true" to enable the @vitejs/plugin-basic-ssl dev server.
# Required when testing BFF flows that set Secure cookies.
#
VITE_USE_HTTPS=false
